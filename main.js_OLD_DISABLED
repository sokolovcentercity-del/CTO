let _aiProvider = 'yandex'; // по умолчанию, уточняется при первом запросе
async function detectProvider() {
  try {
    const resp = await fetch('./api/handler.php?test=1');
    const data = await resp.json();
    _aiProvider = data.provider || 'yandex';
    console.log('[doc-checker] AI провайдер:', _aiProvider);
  } catch { /* используем дефолт */ }
}

