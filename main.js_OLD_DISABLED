// ─── Состояние ───────────────────────────────────────────────────────────────

const zones = {
  1: { files: [], multiple: false },
  2: { files: [], multiple: true  },
  3: { files: [], multiple: true  },
  4: { files: [], multiple: true  },
};

let analyzing = false;
let results   = null;
let fileIdCounter = 0;

const MAX_MB = 20;
const ALLOWED_EXTS = ['pdf', 'docx', 'doc', 'xlsx', 'xls', 'txt', 'csv', 'md', 'png', 'jpg', 'jpeg'];
const CONCURRENCY    = 2;
const BATCH_PAUSE_MS = 3000;
const PATTERNS_KEY   = 'doc_checker_patterns_v1';

let _userPatterns = []; // пользовательские паттерны (из sessionStorage)

// ─── DOM ─────────────────────────────────────────────────────────────────────

