function buildExcelBlob(XLSX) {
  const { summaryData, issues } = results;
  const wb = XLSX.utils.book_new();

  const tableRows = [];
  const merges    = [];
  tableRows.push(['Наименование товара', 'Ед.', 'Кол-во', 'Цена', 'Без НДС', 'НДС', 'С НДС']);

  (summaryData || []).forEach(section => {
    const sectionRow = tableRows.length;
    tableRows.push([section.label, '', '', '', '', '', '']);
    merges.push({ s: { r: sectionRow, c: 0 }, e: { r: sectionRow, c: 6 } });

    const meta = [];
    if (section.docDate) meta.push('Дата: ' + section.docDate);
    if (section.seller?.name) meta.push('Поставщик: ' + section.seller.name);
    if (section.buyer?.name)  meta.push('Получатель: ' + section.buyer.name);
    if (meta.length) {
      const mr = tableRows.length;
      tableRows.push([meta.join(' | '), '', '', '', '', '', '']);
      merges.push({ s: { r: mr, c: 0 }, e: { r: mr, c: 6 } });
    }

    if (section.kind === 'extra') {
      if (section.claimAmount)  tableRows.push(['Сумма претензии', '', '', '', '', '', fmt(section.claimAmount) + ' руб.']);
      if (section.claimSubject) tableRows.push(['Предмет претензии', section.claimSubject, '', '', '', '', '']);
      if (section.notes) tableRows.push(['Примечания', section.notes, '', '', '', '', '']);
      tableRows.push(['', '', '', '', '', '', '']);
      return;
    }

    (section.items || []).forEach(item => {
      tableRows.push([item.name||'', item.unit||'', item.qty!=null?item.qty:'',
        item.price?Number(item.price):'', item.amount?Number(item.amount):'',
        item.vat_amount?Number(item.vat_amount):'', item.total?Number(item.total):'']);
    });

    const t = section.totals || {};
    const tr = tableRows.length;
    tableRows.push(['Итого','','','',
      t.amount_no_vat?Number(t.amount_no_vat):'',
      t.vat_amount?Number(t.vat_amount):'',
      t.amount_with_vat?Number(t.amount_with_vat):'']);
    merges.push({ s: { r: tr, c: 0 }, e: { r: tr, c: 3 } });

    if (section.kind === 'aggregate' && section.compareWith) {
      const diff = round2(Math.abs((t.amount_with_vat||0)-(section.compareWith.amount_with_vat||0)));
      const cr = tableRows.length;
      tableRows.push([diff<0.02?'✅ Совпадает':'🔴 Расхождение: '+fmt(diff)+' руб.','','','',
        section.compareWith.amount_no_vat?Number(section.compareWith.amount_no_vat):'',
        section.compareWith.vat_amount?Number(section.compareWith.vat_amount):'',
        section.compareWith.amount_with_vat?Number(section.compareWith.amount_with_vat):'']);
      merges.push({ s: { r: cr, c: 0 }, e: { r: cr, c: 3 } });
    }
    tableRows.push(['','','','','','','']);
  });

  const ws1 = XLSX.utils.aoa_to_sheet(tableRows);
  ws1['!merges'] = merges;
  ws1['!cols'] = [{ wch: 45 }, { wch: 6 }, { wch: 8 }, { wch: 14 }, { wch: 14 }, { wch: 12 }, { wch: 14 }];
  XLSX.utils.book_append_sheet(wb, ws1, 'Сводная таблица');

  const SEV_RU    = { critical: 'Критично', significant: 'Существенно', warning: 'Замечание', info: 'Информация' };
  const issueRows = [['Категория', 'Уровень', 'Нарушение', 'Детали']];
  (issues || []).forEach(i => {
    issueRows.push([i.category||'', SEV_RU[i.severity]||i.severity, i.message||'', i.detail||'']);
  });
  const ws2 = XLSX.utils.aoa_to_sheet(issueRows);
  ws2['!cols'] = [{ wch: 22 }, { wch: 14 }, { wch: 60 }, { wch: 50 }];
  XLSX.utils.book_append_sheet(wb, ws2, 'Нарушения');

  const wbout = XLSX.write(wb, { bookType: 'xlsx', type: 'array' });
  return new Blob([wbout], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
}

async function loadXLSX() {
  if (window.XLSX) return window.XLSX;
  await new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js';
    s.onload = resolve;
    s.onerror = () => {
      const s2 = document.createElement('script');
      s2.src = 'https://unpkg.com/xlsx@0.18.5/dist/xlsx.full.min.js';
      s2.onload = resolve; s2.onerror = reject;
      document.head.appendChild(s2);
    };
    document.head.appendChild(s);
  });
  return window.XLSX;
}

function buildRtfReport() {
  const { issues, conclusion, documents, summaryData } = results;
  const date = new Date().toLocaleString('ru-RU');

  function rtfStr(s) {
    return (s || '').replace(/\\/g, '\\\\').replace(/\{/g, '\\{').replace(/\}/g, '\\}')
      .replace(/[^\u0000-\u007F]/g, ch => {
        const code = ch.charCodeAt(0);
        return '\\u' + (code > 32767 ? code - 65536 : code) + '?';
      });
  }
  function h1(s)  { return '{\\pard\\sb240\\sa120\\b\\fs32 ' + rtfStr(s) + '\\b0\\par}\n'; }
  function h2(s)  { return '{\\pard\\sb200\\sa80\\b\\fs26 ' + rtfStr(s) + '\\b0\\par}\n'; }
  function para(s) { return '{\\pard\\sa80 ' + rtfStr(s) + '\\par}\n'; }

  function tblRow(cells, widths, shading) {
    const W = widths || [5000, 800, 1000, 1500, 1800, 1500, 1800];
    let hdr = '\\trowd\\trgaph108\\trleft-108';
    let pos = 0;
    W.forEach(w => { pos += w; hdr += (shading ? '\\clcbpat' + shading : '') + '\\cellx' + pos; });
    const body = cells.map(c => '{\\pard\\intbl\\sa0 ' + rtfStr(String(c ?? '')) + '\\cell}').join('');
    return hdr + '\n' + body + '\\row\n';
  }

  let rtf = '{\\rtf1\\ansi\\ansicpg1251\\deff0\n';
  rtf += '{\\fonttbl{\\f0\\froman\\fcharset204 Times New Roman;}{\\f1\\fswiss\\fcharset204 Arial;}}\n';
  rtf += '{\\colortbl;\\red0\\green0\\blue0;\\red220\\green53\\blue53;\\red221\\green107\\blue32;\\red215\\green158\\blue46;\\red2\\green132\\blue199;\\red22\\green163\\blue74;}\n';
  rtf += '\\f1\\fs22\\lang1049\n';
  rtf += h1('Отчёт проверки пакета документов на оплату');
  rtf += para('Дата: ' + date + ' | Документов: ' + documents.length);

  rtf += h2('Проверенные документы');
  documents.forEach(d => { rtf += para(d.filename + ' — ' + getTypeLabel(d.type)); });

  rtf += h2('Сводная таблица');
  const COL_W = [4200, 500, 700, 1200, 1400, 1200, 1400];
  rtf += tblRow(['Наименование товара','Ед.','Кол.','Цена','Без НДС','НДС','С НДС'], COL_W, 13421772);

  (summaryData || []).forEach(section => {
    rtf += tblRow([section.label,'','','','','',''], COL_W, 14540253);
    const meta = [];
    if (section.docDate) meta.push('Дата: ' + section.docDate);
    if (section.seller?.name) meta.push('Поставщик: ' + section.seller.name);
    if (section.buyer?.name)  meta.push('Получатель: ' + section.buyer.name);
    if (meta.length) rtf += tblRow([meta.join(' | '),'','','','','',''], COL_W);

    if (section.kind === 'extra') {
      if (section.claimAmount)  rtf += tblRow(['Сумма претензии','','','','','',fmt(section.claimAmount)+' руб.'], COL_W);
      if (section.claimSubject) rtf += tblRow(['Предмет: '+(section.claimSubject||''),'','','','','',''], COL_W);
      if (section.notes)        rtf += tblRow(['Примечания: '+section.notes,'','','','','',''], COL_W);
      return;
    }

    (section.items || []).forEach(item => {
      rtf += tblRow([item.name||'', item.unit||'',
        item.qty!=null?String(item.qty):'',
        item.price?fmt(item.price):'',
        item.amount?fmt(item.amount):'',
        item.vat_amount?fmt(item.vat_amount):'',
        item.total?fmt(item.total):''], COL_W);
    });

    const t = section.totals || {};
    rtf += tblRow(['Итого','','','',
      t.amount_no_vat?fmt(t.amount_no_vat):'',
      t.vat_amount?fmt(t.vat_amount):'',
      t.amount_with_vat?fmt(t.amount_with_vat):''], COL_W, 14737632);

    if (section.kind === 'aggregate' && section.compareWith) {
      const diff = round2(Math.abs((t.amount_with_vat||0)-(section.compareWith.amount_with_vat||0)));
      const ok = diff < 0.02;
      rtf += tblRow([ok?'Совпадает':'Расхождение: '+fmt(diff)+' руб.','','','',
        fmt(section.compareWith.amount_no_vat||0),
        fmt(section.compareWith.vat_amount||0),
        fmt(section.compareWith.amount_with_vat||0)], COL_W, ok?13828096:16744448);
    }
  });

  rtf += h2('Нарушения (' + issues.length + ')');
  const SEV_RU = { critical: 'КРИТИЧНО', significant: 'СУЩЕСТВЕННО', warning: 'ЗАМЕЧАНИЕ', info: 'ИНФО' };
  const SEV_CF = { critical: '\\cf2', significant: '\\cf3', warning: '\\cf4', info: '\\cf5' };
  if (!issues.length) {
    rtf += para('Нарушений не выявлено');
  } else {
    issues.forEach(issue => {
      const cf = SEV_CF[issue.severity] || '';
      rtf += '{\\pard\\sa60 ' + cf + '{\\b [' + rtfStr(SEV_RU[issue.severity]||issue.severity) + ']} \\cf0' +
        (issue.category?' '+rtfStr(issue.category)+':':'') + ' {\\b ' + rtfStr(issue.message) + '}\\par}\n';
      if (issue.detail) rtf += '{\\pard\\sa80\\li360\\fs18\\cf0 ' + rtfStr(issue.detail) + '\\par}\n';
    });
  }

  rtf += h2('Заключение AI (Claude)');
  (conclusion||'').split(/\n\n+/).forEach(p => {
    if (!p.trim()) return;
    rtf += para(p.replace(/^#{1,4}\s+/,'').replace(/\*\*/g,'').replace(/\*/g,''));
  });

  rtf += '}';
  return rtf;
}

async function loadJSZip() {
  if (window.JSZip) return window.JSZip;
  await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js')
    .catch(() => loadScript('https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js'));
  if (!window.JSZip) throw new Error('JSZip не загружен');
  return window.JSZip;
}

function loadScript(src) {
  return new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = src; s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

function dateSlug() { return new Date().toISOString().slice(0, 10); }

function triggerDownload(blob, filename) {
  const url = URL.createObjectURL(blob);
  const a   = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 5000);
}

function setProgress(pct, stage, detail) {
  if (pct !== null) {
    $('progressBar').style.width = pct + '%';
    $('progressBar').setAttribute('aria-valuenow', pct);
  }
  if (stage)  $('progressStageLabel').textContent = stage;
  if (detail) $('progressText').textContent = detail;
}

function markdownToHtml(text) {
  return (text || '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/^### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^## (.+)$/gm, '<h3>$1</h3>')
    .replace(/^# (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(?!<[hul])(.+)$/gm, '<p>$1</p>')
    .replace(/<p><\/p>/g, '');
}

function escHtml(str) {
  return (str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function showToast(message, type = 'info', duration = 4500) {
  const container = $('toastContainer');
  if (!container) return;
  const toast = document.createElement('div');
  toast.className = 'toast toast-' + type;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), duration);
}

// ─── Система паттернов ────────────────────────────────────────────────────────

const PATTERNS_KEY = 'doc_checker_patterns_v1';
let _userPatterns = [];

function loadUserPatterns() {
  try { const raw = sessionStorage.getItem(PATTERNS_KEY); _userPatterns = raw ? JSON.parse(raw) : []; } catch { _userPatterns = []; }
  updatePatternsBadge();
}

function saveUserPatterns() {
  try { sessionStorage.setItem(PATTERNS_KEY, JSON.stringify(_userPatterns)); } catch { /* */ }
  updatePatternsBadge();
}

function updatePatternsBadge() {
  const badge = $('patternsBadge');
  if (badge) badge.textContent = _userPatterns.length > 0 ? String(_userPatterns.length) : '';
}

export function getUserPatternsPrompt() {
  if (!_userPatterns.length) return '';
  const lines = _userPatterns.map((p, i) =>
    `Паттерн ${i + 1} (${p.source}, поле ${p.field}):\n  Неверно: ${p.example_wrong}\n  Верно:   ${p.example_correct}\n  Правило: ${p.rule}`
  ).join('\n\n');
  return '\n\nПОЛЬЗОВАТЕЛЬСКИЕ ПАТТЕРНЫ ОШИБОК (выявлены на предыдущих анализах):\n' + lines + '\n\nОБЯЗАТЕЛЬНО учти эти паттерны при извлечении данных!';
}

function openFeedback(issueMsg) {
  $('fbDocFile').value  = allFiles().map(f => f.name).join(', ') || '';
  $('fbWrong').value    = '';
  $('fbCorrect').value  = '';
  $('fbContext').value  = issueMsg || '';
  $('fbField').value    = 'price';
  $('fbPatternPreview').classList.add('hidden');
  $('feedbackOverlay').classList.remove('hidden');
  setTimeout(() => $('fbWrong').focus(), 100);
}

function closeFeedback() { $('feedbackOverlay').classList.add('hidden'); }

function updatePatternPreview() {
  const wrong = $('fbWrong').value.trim(), correct = $('fbCorrect').value.trim();
  if (!wrong || !correct) { $('fbPatternPreview').classList.add('hidden'); return; }
  $('fbPatternJson').textContent = JSON.stringify(buildPatternFromForm(), null, 2);
  $('fbPatternPreview').classList.remove('hidden');
}

function buildPatternFromForm() {
  return {
    id: 'user_' + Date.now(), source: 'Пользователь — ' + new Date().toLocaleDateString('ru-RU'),
    doc_type: 'auto', field: $('fbField').value,
    example_wrong: $('fbWrong').value.trim(), example_correct: $('fbCorrect').value.trim(),
    rule: $('fbContext').value.trim() || `Поле "${$('fbField').value}": вместо "${$('fbWrong').value.trim()}" должно быть "${$('fbCorrect').value.trim()}"`,
    added_by: 'user', added_at: new Date().toISOString().slice(0, 10),
  };
}

function saveFeedbackPattern() {
  if (!$('fbWrong').value.trim() || !$('fbCorrect').value.trim()) { showToast('Заполните поля «Что прочитано» и «Как должно быть»', 'warning'); return; }
  _userPatterns.push(buildPatternFromForm());
  saveUserPatterns();
  closeFeedback();
  showToast('✅ Паттерн сохранён. Будет учтён при следующем анализе.', 'success', 5000);
}

function openPatternsModal() { renderPatternsList(); $('patternsOverlay').classList.remove('hidden'); }

function renderPatternsList() {
  const wrap = $('patternsListWrap'); if (!wrap) return;
  const systemPatterns = [{ id: 'sys_1', source: 'УПД ФНС — цена', field: 'price', added_by: 'system', rule: 'PDF разбивает цену на части. Пример: «238 352,31 05269930» = 238352.3105269930. НЕ обрезать после 2 знаков.', example_wrong: '238352.31', example_correct: '238352.3105269930' }];
  const all = [...systemPatterns, ..._userPatterns];
  if (!all.length) { wrap.innerHTML = '<div class="patterns-empty">Паттернов пока нет</div>'; return; }
  wrap.innerHTML = all.map(p => {
    const isUser = p.added_by === 'user';
    return '<div class="pattern-item ' + (isUser ? 'pattern-user' : 'pattern-system') + '">' +
      '<div class="pattern-item-header"><span class="pattern-item-source">' + escHtml(p.source) + ' — поле: ' + escHtml(p.field) + '</span>' +
      '<div style="display:flex;gap:0.4rem;align-items:center;"><span class="pattern-item-badge ' + (isUser ? 'pattern-badge-user' : 'pattern-badge-system') + '">' + (isUser ? '👤 Пользователь' : '⚙️ Системный') + '</span>' +
      (isUser ? '<button class="pattern-item-delete" data-pattern-id="' + escHtml(p.id) + '" title="Удалить">✕</button>' : '') + '</div></div>' +
      '<div class="pattern-item-rule">' + escHtml(p.rule) + '</div>' +
      (p.example_wrong && p.example_correct ? '<div class="pattern-item-example"><span class="pattern-ex-wrong">' + escHtml(p.example_wrong) + '</span><span class="pattern-ex-arrow">→</span><span class="pattern-ex-correct">' + escHtml(p.example_correct) + '</span></div>' : '') +
    '</div>';
  }).join('');
  wrap.addEventListener('click', e => { const btn = e.target.closest('.pattern-item-delete'); if (!btn) return; _userPatterns = _userPatterns.filter(p => p.id !== btn.dataset.patternId); saveUserPatterns(); renderPatternsList(); showToast('Паттерн удалён', 'info'); });
}

function clearUserPatterns() {
  if (!_userPatterns.length) { showToast('Пользовательских паттернов нет', 'info'); return; }
  if (!confirm('Удалить все ' + _userPatterns.length + ' пользовательских паттернов?')) return;
  _userPatterns = []; saveUserPatterns(); renderPatternsList(); showToast('Пользовательские паттерны очищены', 'success');
}

